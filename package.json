{
  "name": "@taurus-ai/swarm-spawner",
  "version": "0.3.1",
  "description": "Ephemeral AI agent orchestration system with Hedera blockchain auditability",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "swarm-spawner": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hedera": {
      "types": "./dist/hedera-integration.d.ts",
      "import": "./dist/hedera-integration.js",
      "default": "./dist/hedera-integration.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "ephemeral",
    "swarm",
    "hedera",
    "blockchain",
    "post-quantum",
    "pqc"
  ],
  "author": "TAURUS AI Corp <admin@taurusai.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taurus-Ai-Corp/swarm-spawner.git"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.81.0",
    "@noble/hashes": "^2.0.1",
    "@noble/post-quantum": "^0.6.0",
    "events": "^3.3.0"
  }
}
